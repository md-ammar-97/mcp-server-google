# -------------------------------------------------------------------
# Google MCP Server — environment variables
# Copy this file to .env and fill in values before running locally.
# Never commit .env to version control.
# -------------------------------------------------------------------

# SERVER_API_KEY is the value the SERVER expects.
# Clients must send it as the HTTP request header:  X-Api-Key: <value>
# Leave blank to disable authentication (local dev only).
SERVER_API_KEY=

# NOTE: X-API-KEY is NOT an application environment variable.
# "X-Api-Key" is only the HTTP header name that clients use when calling the API.
# Do not add X-API-KEY here — it will be ignored by the application.

# Approval mode for Google API actions.
# terminal — print action to stdout and wait for y/n (default, requires TTY)
# auto      — approve all automatically (required for Cloud Run / headless environments)
APPROVAL_MODE=terminal

# Paths to Google OAuth 2.0 credential files (used for local development).
# In Cloud Run, GOOGLE_CREDENTIALS_JSON and GOOGLE_TOKEN_JSON are injected
# from Secret Manager instead — do not set these in production.
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# Cloud Run injects PORT automatically — do not set it in production.
# Default for local development: 8000
PORT=8000
