# -------------------------------------------------------------------
# Google MCP Server — environment variables
# Copy this file to .env and fill in values before running the server.
# Never commit .env to version control.
# -------------------------------------------------------------------

# Optional. When set, all non-health endpoints require this value in
# the X-API-Key request header. Leave blank to disable (local dev only).
SERVER_API_KEY=

# Approval mode for Google API actions.
# terminal — print action to stdout and wait for y/n (default, requires TTY)
# auto      — approve all actions automatically (use only for trusted pipelines)
APPROVAL_MODE=terminal

# Paths to Google OAuth 2.0 credential files.
# Defaults to files in the current working directory.
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# Port the server listens on. Default: 8000.
PORT=8000
